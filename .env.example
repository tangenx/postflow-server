# Change if you are using a remote database
DB_HOST=postflow-db
DB_NAME=postflow
DB_USER=postflow
DB_PASSWORD=REPLACE_PASS
DB_INIT_ARGS=

SERVER_PORT=5555

# Set to true to enable global authentication.
AUTHENTICATION_ENABLED=true

# JWT secret — generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_ME

# Token TTL in seconds (defaults: access=1800/30min, refresh=604800/7d)
JWT_ACCESS_TTL=1800
JWT_REFRESH_TTL=604800

# Storage type (local/s3) - case sensitive!
STORAGE_TYPE=s3
# Local storage path (only for local storage)
LOCAL_STORAGE_PATH=/data/storage
# Garage S3 credentials
S3_ENDPOINT=http://s3:3900
S3_REGION=garage
S3_BUCKET=anime-posting
S3_ACCESS_KEY=REPLACE_S3_ACCESS_KEY
S3_SECRET_KEY=REPLACE_S3_SECRET_KEY