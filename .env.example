# Change if you are using a remote database
DB_HOST=postflow-db
DB_NAME=postflow
DB_USER=postflow
DB_PASSWORD=REPLACE_PASS
DB_INIT_ARGS=

SERVER_PORT=5555

# Set to true to enable global authentication.
AUTHENTICATION_ENABLED=true

# JWT secret — generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_ME

# Token TTL in seconds (defaults: access=1800/30min, refresh=604800/7d)
JWT_ACCESS_TTL=1800
JWT_REFRESH_TTL=604800